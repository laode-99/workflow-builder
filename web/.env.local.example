# Copy this file to .env.local and adjust for your local setup.
#
# NEXT_PUBLIC_API_URL: where the Go API (cmd/api) is listening.
# Default: http://localhost:8080
NEXT_PUBLIC_API_URL=http://localhost:8080

# NEXT_PUBLIC_ADMIN_API_KEY: must match the ADMIN_API_KEY env var on the
# Go API side. The Go middleware checks X-API-Key on every protected route.
# Dev default: "admin-secret-dev" (matches the fallback in middleware_auth.go).
# In production, generate a strong random value and set it on BOTH sides.
NEXT_PUBLIC_ADMIN_API_KEY=admin-secret-dev
